<?xml version="1.0" encoding="UTF-8"?>
<manifest>
  <!--
    HRCustom ROM - local manifest
    Base: LineageOS 23.2 (Android 16)
    Device trees marble (Poco F5): Chaitanyakm (branch 16.0)
    Kernel/hardware Xiaomi: LineageOS (lineage-23.2)
    Instrucoes de init/sync/build em SYNC.md e BUILD.md.
  -->

  <!-- Remotes (nomes unicos pra nao conflitar com a base LineageOS) -->
  <remote name="chaitanya" fetch="https://github.com/Chaitanyakm/"
          revision="refs/heads/16.0" />
  <remote name="los"       fetch="https://github.com/LineageOS/"
          revision="refs/heads/lineage-23.2" />

  <!-- ============ Poco F5 (marble / sm8450) ============ -->

  <!-- Device trees + blobs proprietarios: Chaitanyakm (16.0) -->
  <project path="device/xiaomi/marble"
           name="device_xiaomi_marble"          remote="chaitanya" />
  <project path="device/xiaomi/sm8450-common"
           name="device_xiaomi_sm8450-common"   remote="chaitanya" />
  <project path="vendor/xiaomi/marble"
           name="vendor_xiaomi_marble"          remote="chaitanya" />
  <project path="vendor/xiaomi/sm8450-common"
           name="vendor_xiaomi_sm8450-common"   remote="chaitanya" />

  <!-- Kernel + hardware Xiaomi: LineageOS (lineage-23.2) -->
  <project path="kernel/xiaomi/sm8450"
           name="android_kernel_xiaomi_sm8450"             remote="los" />
  <project path="kernel/xiaomi/sm8450-devicetrees"
           name="android_kernel_xiaomi_sm8450-devicetrees" remote="los" />
  <project path="kernel/xiaomi/sm8450-modules"
           name="android_kernel_xiaomi_sm8450-modules"     remote="los" />
  <project path="hardware/xiaomi"
           name="android_hardware_xiaomi"                  remote="los" />

  <!-- ============ Poco F1 (beryllium) ============ -->
  <!-- TODO: adicionar apos verificar deps completas (kernel sdm845 so tem
       lineage-22.2; blobs ficam no TheMuppets). Sera incluso numa proxima
       atualizacao pra nao quebrar o sync do marble. -->

</manifest>
